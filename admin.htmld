function shuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
let curQ=0,ans=[],QS=[],uName='',uRegion='',uBiz='',rChart=null;

function show(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');window.scrollTo(0,0);}
function goHome(){show('sw');}

// 날짜 자동 입력
window.addEventListener('load',function(){
  const now=new Date();
  const yyyy=now.getFullYear();
  const mm=String(now.getMonth()+1).padStart(2,'0');
  const dd=String(now.getDate()).padStart(2,'0');
  const dateStr=yyyy+'.'+mm+'.'+dd;
  document.getElementById('dateDisplay').textContent='📅 '+dateStr;
  document.getElementById('dateIn').value=dateStr;

  // 강사 접속 (상단 5번 탭)
  const hero=document.querySelector('.w-hero');
  if(hero)hero.addEventListener('click',function(){
    tapCount++;clearTimeout(tapTimer);tapTimer=setTimeout(()=>{tapCount=0;},2000);
    if(tapCount>=5){tapCount=0;goAdminPw();}
  });
});

function startQuiz(){
  const n=document.getElementById('nameIn').value.trim();
  const d=document.getElementById('dateIn').value;
  const r=document.getElementById('regionIn').value;
  if(!n){document.getElementById('inputErr').style.display='block';return;}
  document.getElementById('inputErr').style.display='none';
  uName=n+'('+d+')'; uRegion=r; uBiz='';
  QS=shuffle(QS_ORIG); ans=new Array(40).fill(null); curQ=0;
  renderQ(); show('sq');
}

function renderQ(){
  const q=QS[curQ],ar=AREAS[q.a];
  const pill=document.getElementById('aPill');
  pill.textContent=ar.l+'. '+ar.n; pill.style.background=ar.c+'22'; pill.style.color=ar.c;
  document.getElementById('qCnt').textContent=(curQ+1)+' / 40';
  const pct=Math.round(((curQ+1)/40)*100);
  document.getElementById('qPct').textContent=pct+'% 완료';
  document.getElementById('pF').style.width=pct+'%';
  document.getElementById('qNum').textContent='문항 '+String(curQ+1).padStart(2,'0');
  document.getElementById('qTxt').textContent=q.t;
  [5,4,3,2,1].forEach(n=>{const b=document.getElementById('btn'+n);b.className='sc-btn s'+n;if(ans[curQ]===n)b.classList.add('sel');});
  const fb=document.getElementById('selFb');
  if(ans[curQ]!==null){fb.textContent=SEL_LABELS[ans[curQ]];fb.style.color=SEL_COLORS[ans[curQ]];}else fb.textContent='';
  const bn=document.getElementById('bNext');
  bn.disabled=ans[curQ]===null; bn.textContent=curQ===39?'결과 보기 →':'다음 문항 →';
}
function pick(s){ans[curQ]=s;renderQ();setTimeout(()=>nextQ(),350);}
function nextQ(){if(ans[curQ]===null)return;if(curQ<39){curQ++;renderQ();}else showResult();}
function prevQ(){if(curQ>0){curQ--;renderQ();}else show('sw');}

function calcScores(){return AREAS.map((_,i)=>Math.round((QS.reduce((acc,q,qi)=>q.a===i?acc+(ans[qi]||0):acc,0)/5)*10)/10);}
function calcQScores(){const r=new Array(40).fill(0);QS.forEach((q,qi)=>{r[q.id]=ans[qi]||0;});return r;}
function sc(s){return s>=4?'#2E7D5A':s>=3?'#B06000':'#B03030';}
function scBg(s){return s>=4?'#EAF5EE':s>=3?'#FDF3E3':'#FAEAEA';}

// 종합 점수별 공감 메시지
function getTotalMessage(tot, scores){
  const maxIdx=scores.indexOf(Math.max(...scores));
  const minIdx=scores.indexOf(Math.min(...scores));
  const strongArea=AREAS[maxIdx].l+'. '+AREAS[maxIdx].n;
  if(tot>=4.0){
    return {
      icon:'🌱',
      bg:'#EAF5EE',color:'#1E6040',border:'#A8D8BC',
      title:'새출발 준비가 잘 되어 있어요',
      msg:'전반적으로 안정적인 상태예요. 특히 <strong>'+strongArea+'</strong> 영역의 강점을 중심으로 새로운 방향을 구체화해 나가기에 좋은 시점이에요. 지금의 에너지를 유지하면서 한 걸음씩 나아가 보세요.',
      action:'이번 주 실천 제안: 가장 자신 있는 영역을 활용해 작은 목표 하나를 써보세요.'
    };
  } else if(tot>=3.0){
    return {
      icon:'🌿',
      bg:'#FDF3E3',color:'#8B4500',border:'#F0C070',
      title:'조금씩 앞으로 나아가고 있어요',
      msg:'지금은 준비 중인 상태예요. 완전히 준비된 상태가 아니어도 괜찮아요. <strong>'+strongArea+'</strong> 영역이 상대적으로 잘 되어 있으니, 이것을 발판 삼아 취약한 부분을 하나씩 채워나가 보세요.',
      action:'이번 주 실천 제안: 가장 쉽게 시작할 수 있는 취약 영역 하나를 골라 작은 행동 하나만 해보세요.'
    };
  } else {
    return {
      icon:'💙',
      bg:'#EEF2FF',color:'#1E3A7B',border:'#B0C0F0',
      title:'지금 이 자리에 오신 것 자체가 용기예요',
      msg:'지금은 많이 힘드신 시기일 거예요. 그럼에도 이 진단을 해보신 것은 변화를 원한다는 마음의 신호예요. 지금 당장 모든 걸 해결하지 않아도 돼요. <strong>'+strongArea+'</strong> 영역에서 보이는 가능성을 출발점으로 삼아보세요.',
      action:'이번 주 실천 제안: 오늘 하루 가장 쉬운 것 하나만 해보세요. 작은 행동이 변화의 시작이에요.'
    };
  }
}

// 강점 영역 칭찬 메시지
const STRONG_MSG={
  0:'감정을 조절하고 변화에 적응하는 힘이 있어요. 새출발 과정에서 흔들릴 때 이 회복력이 가장 큰 자산이 될 거예요.',
  1:'재무 상황을 파악하고 대비하는 능력이 있어요. 이 안정감이 새로운 도전을 위한 든든한 기반이 돼요.',
  2:'건강을 챙기는 습관이 잡혀 있어요. 몸과 마음의 건강은 어떤 새출발에서도 가장 중요한 자원이에요.',
  3:'앞으로의 방향을 탐색하고 준비하는 힘이 있어요. 이 실행력이 새출발을 현실로 만들어 줄 거예요.',
  4:'나를 위한 시간과 즐거움을 만드는 능력이 있어요. 이 여유로움이 지속 가능한 새출발의 에너지원이에요.',
  5:'앞으로의 삶을 설계하는 눈이 있어요. 방향이 보이는 사람은 반드시 그곳에 도달해요.',
  6:'주변 사람들과 관계를 유지하는 힘이 있어요. 이 연결망이 새출발 과정에서 가장 큰 지지대가 될 거예요.',
  7:'생활 공간을 안정적으로 유지하고 있어요. 안전한 공간은 마음의 여유를 만들고 재기의 토대가 돼요.',
};

// 즉시 실행 행동 제안
const ACTION_TIP={
  0:'오늘 저녁 10분, 지금 드는 감정을 종이에 써보세요. 감정을 인식하는 것이 회복의 시작이에요.',
  1:'이번 주 안에 수입·지출 현황을 메모 한 장에 정리해 보세요.',
  2:'오늘부터 하루 세 끼 식사 시간을 정해두고 지켜보세요.',
  3:'내가 잘했던 일 3가지를 종이에 적어보세요. 경험은 사라지지 않아요.',
  4:'오늘 30분, 좋아했던 것을 다시 해보세요. 즐거움도 연습이 필요해요.',
  5:'"1년 후 나는 ○○하고 있다"를 한 문장으로 써보세요.',
  6:'오랫동안 연락 못한 지인 한 명에게 문자를 보내보세요.',
  7:'집 안 한 곳을 정리하고 나만의 편안한 자리를 만들어 보세요.',
};

function showResult(){
  const scores=calcScores(),qScores=calcQScores();
  const tot=Math.round((scores.reduce((a,b)=>a+b,0)/8)*10)/10;
  document.getElementById('rName').textContent=uName.split('(')[0]+'님의';
  document.getElementById('totalN').textContent=tot.toFixed(1);
  document.getElementById('totalN').style.color=sc(tot);
  document.getElementById('savedOk').style.display='none';

  const bars=document.getElementById('sBars');bars.innerHTML='';
  scores.forEach((s,i)=>{const c=sc(s);bars.innerHTML+=`<div class="s-row"><span class="s-nm">${AREAS[i].l}. ${AREAS[i].n}</span><div class="s-bar-bg"><div class="s-bar" style="width:${s/5*100}%;background:${c}"></div></div><span class="s-val" style="color:${c}">${s}</span></div>`;});

  // ① 종합 공감 메시지 카드
  const totalMsg=getTotalMessage(tot,scores);
  const totalCard=document.getElementById('totalMsgCard');
  totalCard.style.display='block';
  totalCard.innerHTML=`
    <div style="background:${totalMsg.bg};border:1px solid ${totalMsg.border};border-radius:var(--r-lg);padding:1.5rem">
      <div style="font-size:28px;margin-bottom:.75rem">${totalMsg.icon}</div>
      <div style="font-size:17px;font-weight:700;color:${totalMsg.color};margin-bottom:.6rem">${totalMsg.title}</div>
      <div style="font-size:15px;color:${totalMsg.color};line-height:1.75;margin-bottom:1rem">${totalMsg.msg}</div>
      <div style="background:rgba(255,255,255,.6);border-radius:10px;padding:.75rem 1rem;font-size:14px;color:${totalMsg.color};font-weight:600;line-height:1.6">💡 ${totalMsg.action}</div>
    </div>`;

  // ② 영역별 맞춤 피드백 (강점 칭찬 강화 + 취약 행동 제안)
  const fb=document.getElementById('fbCard');
  fb.innerHTML='<div class="card-ttl" style="margin-bottom:1rem">영역별 맞춤 피드백</div>';
  scores.forEach((s,i)=>{
    const areaQs=QS_ORIG.filter(q=>q.a===i);
    const minQ=areaQs.reduce((m,q)=>(qScores[q.id]<qScores[m.id]?q:m));
    const maxQ=areaQs.reduce((m,q)=>(qScores[q.id]>qScores[m.id]?q:m));
    const minScore=qScores[minQ.id];
    const c=sc(s),bg=scBg(s);
    const icon=s>=4?'✅':s>=3?'⚠️':'🔴';
    let h=`<div class="fb-item"><div class="fb-top"><div class="fb-icon" style="background:${bg}">${icon}</div><div><div class="fb-area">${AREAS[i].l}. ${AREAS[i].n}</div></div><div class="fb-score" style="color:${c}">${s}점</div></div>`;
    if(s>=4){
      // 강점: 충분한 칭찬 + 새출발 연계 의미
      h+=`<div class="fb-msg" style="color:#1E6040;line-height:1.7">${STRONG_MSG[i]}</div>
          <div style="background:#D1FAE5;border-radius:8px;padding:8px 12px;margin-top:8px;font-size:13px;color:#065F46;font-weight:600">💡 이번 주 실천: ${ACTION_TIP[i]}</div>`;
    } else {
      // 취약: 공감 + 피드백 + 즉시 행동 제안
      h+=`<div class="fb-weak">특히 "${minQ.t.substring(0,22)}…" 부분을 함께 살펴봐요 (${minScore}점)</div>
          <div class="fb-msg">${Q_FB[minQ.id]}</div>
          <div style="background:rgba(255,255,255,.8);border:1px solid ${s<3?'#F0A0A0':'#F0C070'};border-radius:8px;padding:8px 12px;margin-top:8px;font-size:13px;color:${c};font-weight:600">💡 이번 주 실천: ${ACTION_TIP[i]}</div>`;
    }
    h+='</div>';fb.innerHTML+=h;
  });

  // ③ 재진단 안내
  const recheckCard=document.getElementById('recheckCard');
  recheckCard.style.display='block';
  recheckCard.innerHTML=`
    <div style="background:#F0F4FF;border:1px solid #C0CFFF;border-radius:var(--r-lg);padding:1.25rem;text-align:center">
      <div style="font-size:20px;margin-bottom:.5rem">🔄</div>
      <div style="font-size:15px;font-weight:700;color:#1B3F6E;margin-bottom:.4rem">3개월 후 다시 진단해 보세요</div>
      <div style="font-size:13px;color:#4A5FA0;line-height:1.65">새출발은 하루아침에 이루어지지 않아요.<br>3개월 후 같은 진단을 다시 해보면<br>내가 얼마나 성장했는지 눈으로 확인할 수 있어요. 💪</div>
    </div>`;

  show('sr');
  setTimeout(()=>{if(rChart)rChart.destroy();rChart=makeRadar('rC',scores);},80);
}

function makeRadar(id,scores){
  const ctx=document.getElementById(id)?.getContext('2d');if(!ctx)return null;
  return new Chart(ctx,{type:'radar',
    data:{labels:AREAS.map(a=>a.l+'.'+a.n),datasets:[{data:scores,borderColor:getComputedStyle(document.documentElement).getPropertyValue('--primary').trim()||'#1B3F6E',backgroundColor:'rgba(27,63,110,0.08)',borderWidth:2,pointBackgroundColor:scores.map(s=>sc(s)),pointRadius:6}]},
    options:{responsive:true,maintainAspectRatio:false,scales:{r:{min:0,max:5,ticks:{stepSize:1,font:{size:10},backdropColor:'transparent',color:'#9CA3AF'},grid:{color:'rgba(0,0,0,0.06)'},pointLabels:{font:{size:11,weight:'600'},color:'#4A4A4A',padding:8},angleLines:{color:'rgba(0,0,0,0.06)'}}},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.raw+'점'}}}}
  });
}

async function saveResult(){
  const btn=document.getElementById('saveBtn');
  btn.disabled=true;btn.textContent='저장 중...';
  const scores=calcScores(),qScores=calcQScores();
  const tot=Math.round((scores.reduce((a,b)=>a+b,0)/8)*10)/10;
  const dateStr=new Date().toLocaleDateString('ko-KR',{year:'numeric',month:'2-digit',day:'2-digit'}).replace(/\. /g,'-').replace('.','');
  const rec={name:uName,region:uRegion,biz:uBiz,date:new Date().toLocaleString('ko-KR'),dateOnly:dateStr,scores,qScores,total:tot,ts:Date.now()};
  try{
    if(window._fbReady) await window._setDoc(window._doc(window._db,'soho_results',uName+'_'+Date.now()),rec);
    const ok=document.getElementById('savedOk');
    ok.innerHTML='✅ <strong>'+uName+'님</strong>, 수고하셨어요!<br>진단 결과가 강사님께 전달되었습니다. 😊';
    ok.style.display='block';
    btn.textContent='✅ 저장 완료';
    setTimeout(()=>{ok.style.display='none';btn.disabled=false;btn.textContent='📤 결과 저장하기';},4000);
  }catch(e){btn.disabled=false;btn.textContent='📤 결과 저장하기';alert('저장 오류: '+e.message);}
}

async function captureAndShare(){
  const btn=document.getElementById('captureBtn');
  btn.disabled=true;btn.innerHTML='⏳ 이미지 만드는 중...';
  showFullReport();
  await new Promise(r=>setTimeout(r,800));
  try{
    const el=document.getElementById('reportBody');
    const canvas=await html2canvas(el,{scale:2,useCORS:true,backgroundColor:'#F5F6F8',scrollY:0,width:el.offsetWidth,height:el.scrollHeight,windowHeight:el.scrollHeight});
    const link=document.createElement('a');
    link.download=uName+'_새출발진단결과.png';
    link.href=canvas.toDataURL('image/png');link.click();
    await new Promise(r=>setTimeout(r,500));
    alert('✅ 이미지가 저장되었어요!\n\n카카오톡에서 나에게 보내기\n① 카카오톡 열기 → ② 내 채팅방 선택\n③ 하단 + → 앨범 → 이미지 선택 → 전송!');
  }catch(e){alert('이미지 저장 오류가 발생했어요.\n화면 캡처를 이용해 주세요.');}
  show('sr');
  btn.disabled=false;
  btn.innerHTML='<svg width="20" height="20" viewBox="0 0 24 24" fill="#1A1A1A"><path d="M12 3C6.48 3 2 6.48 2 10.8c0 2.76 1.74 5.19 4.36 6.63l-.88 3.28a.5.5 0 0 0 .74.55l3.9-2.59c.61.09 1.24.13 1.88.13 5.52 0 10-3.48 10-7.8S17.52 3 12 3z"/></svg> 결과 이미지 저장 → 카카오톡으로 보내기';
}

function showFullReport(){
  const scores=calcScores(),qScores=calcQScores();
  const tot=Math.round((scores.reduce((a,b)=>a+b,0)/8)*10)/10;
  const maxIdx=scores.indexOf(Math.max(...scores)),minIdx=scores.indexOf(Math.min(...scores));
  let h=`<div style="background:linear-gradient(135deg,#0D2444,var(--primary));border-radius:var(--r-lg);padding:1.5rem;color:#fff;text-align:center">
    <div style="font-size:14px;color:rgba(255,255,255,.65);margin-bottom:.3rem">${uName}님 · ${uRegion} · ${uBiz}</div>
    <div style="font-size:52px;font-weight:900;color:${sc(tot)};letter-spacing:-2px;line-height:1">${tot.toFixed(1)}</div>
    <div style="font-size:13px;color:rgba(255,255,255,.55);margin-top:.3rem">종합 평균 (5점 만점)</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:1.25rem">
      <div style="background:rgba(255,255,255,.1);border-radius:10px;padding:.75rem"><div style="font-size:11px;color:rgba(255,255,255,.55);margin-bottom:4px">✅ 가장 강한 영역</div><div style="font-size:15px;font-weight:700">${AREAS[maxIdx].l}. ${AREAS[maxIdx].n}</div><div style="font-size:13px;color:rgba(255,255,255,.7)">${scores[maxIdx]}점</div></div>
      <div style="background:rgba(255,255,255,.1);border-radius:10px;padding:.75rem"><div style="font-size:11px;color:rgba(255,255,255,.55);margin-bottom:4px">🔴 집중 지원 영역</div><div style="font-size:15px;font-weight:700">${AREAS[minIdx].l}. ${AREAS[minIdx].n}</div><div style="font-size:13px;color:rgba(255,255,255,.7)">${scores[minIdx]}점</div></div>
    </div>
  </div>`;
  h+=`<div class="card"><div class="card-ttl" style="margin-bottom:1rem">영역별 점수</div>`;
  scores.forEach((s,i)=>{const c=sc(s);h+=`<div class="s-row"><span class="s-nm">${AREAS[i].l}. ${AREAS[i].n}</span><div class="s-bar-bg"><div class="s-bar" style="width:${s/5*100}%;background:${c}"></div></div><span class="s-val" style="color:${c}">${s}</span></div>`;});
  h+=`</div><div class="card"><div class="card-ttl" style="margin-bottom:1rem">맞춤 피드백</div>`;
  scores.forEach((s,i)=>{
    const areaQs=QS_ORIG.filter(q=>q.a===i);
    const minQ=areaQs.reduce((m,q)=>(qScores[q.id]<qScores[m.id]?q:m));
    const c=sc(s),bg=scBg(s),icon=s>=4?'✅':s>=3?'⚠️':'🔴';
    h+=`<div class="fb-item"><div class="fb-top"><div class="fb-icon" style="background:${bg}">${icon}</div><div><div class="fb-area">${AREAS[i].l}. ${AREAS[i].n}</div></div><div class="fb-score" style="color:${c}">${s}점</div></div>`;
    if(s>=4)h+=`<div class="fb-msg" style="color:#1E6040">이 영역은 잘 준비되어 있어요. 이 강점을 새출발의 발판으로 연결해 보세요.</div>`;
    else h+=`<div class="fb-weak">특히 "${minQ.t.substring(0,20)}…" (${qScores[minQ.id]}점)</div><div class="fb-msg">${Q_FB[minQ.id]}</div>`;
    h+='</div>';
  });
  h+=`</div><div class="card"><div class="card-ttl" style="margin-bottom:1rem">문항별 응답 상세</div>`;
  AREAS.forEach((ar,ai)=>{
    h+=`<div style="font-size:13px;font-weight:700;color:${ar.c};margin:12px 0 6px;padding-top:10px;border-top:1px solid var(--line)">${ar.l}. ${ar.n}</div>`;
    QS_ORIG.filter(q=>q.a===ai).forEach(q=>{const v=qScores[q.id]||0;const c=sc(v);h+=`<div style="padding:8px 0;border-bottom:1px solid #F5F5F5;display:flex;gap:10px;align-items:flex-start"><div style="font-size:13px;line-height:1.5;flex:1;color:#4A4A4A;word-break:keep-all">${q.t}</div><div style="font-size:15px;font-weight:700;color:${c};flex-shrink:0;min-width:32px;text-align:right">${v}점</div></div>`;});
  });
  h+='</div>';
  document.getElementById('reportBody').innerHTML=h;
  show('sReport');window.scrollTo(0,0);
}
function savePDF(){showFullReport();setTimeout(()=>{alert('PDF 저장\n\n안드로이드: 브라우저 ⋮ → 공유 → 인쇄 → PDF 저장\n아이폰: 공유 버튼 → 프린트 → 두 손가락 확대 → PDF 저장');window.print();},300);}

let tapCount=0,tapTimer=null;
function goAdminPw(){show('spw');document.getElementById('pwIn').value='';document.getElementById('pwErr').style.display='none';}
function checkPw(){if(document.getElementById('pwIn').value===ADMIN_PW){window.location.href='soho-admin.html';}else document.getElementById('pwErr').style.display='block';}
document.addEventListener('keydown',function(e){if(e.key==='Enter'&&document.getElementById('spw').classList.contains('active'))checkPw();});
</script>
</body>
</html>
